# --- Set by deploy.sh (do not put in .env.local) ---
# REGION is written automatically by deploy.sh based on the --instance flag.
# Used by relay for hostname and by monitor via INSTANCES=${REGION}.
REGION=ap1

# --- Put these in .env.local on each EC2 instance ---

# Optional: override SSH key directory mounted into monitor container
# SSH_DIR=/home/ubuntu/.ssh

# Discord webhook for relay-monitor alerts + hourly summaries
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Monitor thresholds (all optional, defaults shown)
# MAX_CPU_PCT=80
# MAX_LOAD1=2.0
# MAX_MEM_PCT=85
# MAX_DISK_PCT=80
# POLL_MS=300000        # 5 min
# SUMMARY_MS=3600000    # 1 hr

