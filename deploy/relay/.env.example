# Written by deploy.sh — do not edit REGION manually
REGION=ap1

# Optional: override SSH key directory (default: /home/ubuntu/.ssh)
# SSH_DIR=/home/ubuntu/.ssh

# Discord webhook for relay-monitor alerts + hourly summaries
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Secret for the relay metrics endpoint (set in relay.toml metrics_secret)
RELAY_METRICS_SECRET=
