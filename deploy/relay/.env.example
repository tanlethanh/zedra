# Copy this file to deploy/relay/.env (gitignored) before running deploy.sh.
# deploy.sh prepends INSTANCE=<--instance> per host; do not set INSTANCE here — it is injected.
#
# Do not put INSTANCES in this file: that variable is for running monitor/CLI on your
# laptop (INSTANCES=ap1,us1,eu1). The Docker sidecar uses INSTANCE only.

# Required for relay-monitor (Discord alerts + hourly summaries)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Monitor thresholds (all optional; defaults shown)
# MAX_CPU_PCT=80
# MAX_LOAD1=2.0
# MAX_MEM_PCT=85
# MAX_DISK_PCT=80
# POLL_MS=300000        # 5 min
# SUMMARY_MS=3600000    # 1 hr
