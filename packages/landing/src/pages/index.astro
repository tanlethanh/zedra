        </div>
      </section>

      <footer>
        <div class="social-links" aria-label="Zedra social links">
          {
            socialLinks.map((link) => (
              <a
                class="social-btn"
                href={link.href}
                aria-label={link.ariaLabel}
                data-analytics-social={link.analyticsName}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Fragment set:html={link.icon} />
              </a>
            ))
          }
        </div>

        <nav aria-label="Site links">
          <a href="/docs">Docs</a>
          <a href="/remote-code-editor-ipad">Mobile coding</a>
          <a href="/mobile-coding-agents">Mobile agents</a>
          <a href="/claude-code">Claude Code</a>
          <a href="/codex">Codex</a>
          <a href="/compare">Compare</a>
          <a href="/privacy">Privacy</a>
          <a href="/support">Support</a>
        </nav>
      </footer>
    </div>
    <script src="../scripts/analytics.ts"></script>
    <script>
      const CHECK_ICON = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      const COPY_ICON = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

      // Dim galaxy background (original shader — Shadertoy classics like Star
      // Nest are CC BY-NC-SA, so we write our own): three parallax starfield
      // layers with slow twinkle plus a faint noise-broken milky band. All
      // neutral white on the page bg, no color gradients. Half-resolution,
      // 30fps cap, static frame under prefers-reduced-motion; falls back to
      // a 2D "sand" grain field when WebGL is unavailable.
      const bgCanvas = document.getElementById("bg-shader") as HTMLCanvasElement | null;
      const bgReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const bgRun = (resize: () => void, drawFrame: (t: number) => void) => {
        resize();
        drawFrame(20);
        window.addEventListener("resize", () => {
          resize();
          drawFrame(20);
        });
        if (bgReduced) return;
        let last = 0;
        const loop = (ms: number) => {
          requestAnimationFrame(loop);
          if (ms - last < 33) return;
          last = ms;
          drawFrame(ms / 1000);
        };
        requestAnimationFrame(loop);
      };

      const initGalaxy = (canvas: HTMLCanvasElement): boolean => {
        const gl = canvas.getContext("webgl", { antialias: false, depth: false, alpha: false });
        if (!gl) return false;
        const FS = `
          precision highp float;
          uniform float t;
          uniform float rot;
          uniform float pan;
          uniform vec2 r;
          vec2 rot2(vec2 p, float a) {
            float c = cos(a), s = sin(a);
            return vec2(c * p.x - s * p.y, s * p.x + c * p.y);
          }
          float h21(vec2 p) {
            p = fract(p * vec2(123.34, 456.21));
            p += dot(p, p + 45.32);
            return fract(p.x * p.y);
          }
          // clean sci-fi stars: tight gaussian core, soft falloff halo, and
          // diffraction spikes on the brightest ones — no noise, no fuzz
          float stars(vec2 uv, float scale, float tws) {
            vec2 g = uv * scale;
            vec2 id = floor(g);
            vec2 f = fract(g) - 0.5;
            float n = h21(id);
            vec2 off = vec2(h21(id + 1.7), h21(id + 3.1)) - 0.5;
            vec2 q = (f - off * 0.7) / scale;   // screen units
            float d = length(q);
            float m = exp(-d * d * 90000.0) * 1.2;    // crisp core, bigger
            m += exp(-d * d * 5000.0) * 0.18;         // clean glow
            float sp = exp(-abs(q.y) * 700.0) * exp(-abs(q.x) * 90.0)
              + exp(-abs(q.x) * 700.0) * exp(-abs(q.y) * 90.0);
            m += sp * step(0.82, n) * 0.45;           // spikes: bright stars only
            // skip the dimmest third of cells entirely: fewer, bolder stars
            float bright = (0.3 + 0.7 * n * n) * step(0.35, n);
            float tw = 0.78 + 0.22 * sin(t * tws * (0.5 + n) + n * 6.2831);
            return m * bright * tw;
          }
          // shooting stars: several staggered instances, thin fading tails
          float meteorOne(vec2 uv, float seed) {
            float period = 5.0;
            float tt = fract((t + seed * 13.7) / period);
            float k = floor((t + seed * 13.7) / period);
            float win = smoothstep(0.0, 0.02, tt) * (1.0 - smoothstep(0.16, 0.2, tt));
            vec2 start = vec2(
              mix(-0.9, 0.7, h21(vec2(k, 3.0 + seed))),
              mix(-0.1, 0.5, h21(vec2(k, 5.0 + seed))));
            vec2 dir = normalize(vec2(0.85, -0.4));
            vec2 head = start + dir * tt * 3.2;
            vec2 rel = uv - head;
            float along = dot(rel, dir);
            float perp = abs(dot(rel, vec2(-dir.y, dir.x)));
            float inTail = step(-0.28, along) * step(along, 0.0);
            float streak = inTail * exp(along * 9.0) * smoothstep(0.0022, 0.0, perp);
            float headGlow = exp(-length(rel) * 160.0);
            return (streak + headGlow * 0.6) * win;
          }
          float meteor(vec2 uv) {
            return meteorOne(uv, 0.0) + meteorOne(uv, 1.0) + meteorOne(uv, 2.0);
          }
          void main() {
            vec2 uv0 = (gl_FragCoord.xy - 0.5 * r) / r.y;
            // horizontal rotation: the sky pans sideways like sitting on a
            // turning platform; near layers pan faster than far ones
            vec3 col = vec3(0.035);
            // scrolling pans the sky down as well as sideways, per-layer parallax
            float s = stars(uv0 + vec2(rot * 1.5, pan * 1.5), 1.0, 0.9) * 0.6
              + stars(uv0 * 1.6 + 3.7 + vec2(rot * 1.0, pan * 1.0), 1.8, 1.3) * 0.42
              + stars(uv0 * 2.5 + 8.1 + vec2(rot * 0.65, pan * 0.65), 2.9, 1.8) * 0.3;
            col += vec3(0.94, 0.97, 1.0) * min(s, 0.85);
            col += vec3(1.0) * meteor(uv0) * 0.45;
            gl_FragColor = vec4(col, 1.0);
          }`;
        const sh = (type: number, src: string) => {
          const s = gl.createShader(type);
          if (!s) return null;
          gl.shaderSource(s, src);
          gl.compileShader(s);
          return gl.getShaderParameter(s, gl.COMPILE_STATUS) ? s : null;
        };
        const vs = sh(gl.VERTEX_SHADER, "attribute vec2 a;void main(){gl_Position=vec4(a,0.,1.);}");
        const fs = sh(gl.FRAGMENT_SHADER, FS);
        if (!vs || !fs) return false;
        const prog = gl.createProgram();
        if (!prog) return false;
        gl.attachShader(prog, vs);
        gl.attachShader(prog, fs);
        gl.linkProgram(prog);
        if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) return false;
        gl.useProgram(prog);
        gl.bindBuffer(gl.ARRAY_BUFFER, gl.createBuffer());
        gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
        const loc = gl.getAttribLocation(prog, "a");
        gl.enableVertexAttribArray(loc);
        gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
        const uT = gl.getUniformLocation(prog, "t");
        const uR = gl.getUniformLocation(prog, "r");
        const uRot = gl.getUniformLocation(prog, "rot");
        const uPan = gl.getUniformLocation(prog, "pan");
        // scroll steers the sky: sideways rotation + downward pan, both eased
        let rotCur = 0;
        let rotTarget = 0;
        let panCur = 0;
        let panTarget = 0;
        window.addEventListener(
          "scroll",
          () => {
            rotTarget = window.scrollY * 0.00017;
            panTarget = window.scrollY * 0.0002;
          },
          { passive: true },
        );
        bgRun(
          () => {
            // full resolution (capped) so star points render crisp
            const s = Math.min(window.devicePixelRatio || 1, 2);
            canvas.width = Math.max(1, Math.round(window.innerWidth * s));
            canvas.height = Math.max(1, Math.round(window.innerHeight * s));
            gl.viewport(0, 0, canvas.width, canvas.height);
            gl.uniform2f(uR, canvas.width, canvas.height);
          },
          (t) => {
            rotCur += (rotTarget - rotCur) * 0.08;
            panCur += (panTarget - panCur) * 0.08;
            gl.uniform1f(uT, t);
            // constant slow spin (like sitting on a rotating dish) + scroll steer
            gl.uniform1f(uRot, rotCur + t * 0.012);
            gl.uniform1f(uPan, panCur);
            gl.drawArrays(gl.TRIANGLES, 0, 3);
          },
        );
        return true;
      };

      const initSand = (canvas: HTMLCanvasElement) => {
        const ctx = canvas.getContext("2d");
        if (!ctx) return;
        let w = 0;
        let h = 0;
        type Grain = { x: number; y: number; s: number; ph: number; tw: number; drift: number };
        let grains: Grain[] = [];
        const bgRandom = (seed: number) => {
          let v = seed;
          return () => {
            v = (v * 16807) % 2147483647;
            return v / 2147483647;
          };
        };
        bgRun(
          () => {
            w = Math.max(1, Math.round(window.innerWidth * 0.5));
            h = Math.max(1, Math.round(window.innerHeight * 0.5));
            canvas.width = w;
            canvas.height = h;
            const rnd = bgRandom(1337);
            grains = Array.from({ length: Math.round((w * h) / 1600) }, () => ({
              x: rnd() * w,
              y: rnd() * h,
              s: rnd() < 0.85 ? 1 : 2,
              ph: rnd() * Math.PI * 2,
              tw: 0.15 + rnd() * 0.5,
              drift: 0.6 + rnd() * 1.6,
            }));
          },
          (t) => {
            ctx.fillStyle = "#090909";
            ctx.fillRect(0, 0, w, h);
            for (const g of grains) {
              const x = (g.x + t * g.drift) % w;
              const a = 0.02 + 0.09 * Math.sin(t * g.tw + g.ph) ** 2;
              ctx.fillStyle = `rgba(255,255,255,${a})`;
              ctx.fillRect(x, g.y, g.s, g.s);
            }
          },
        );
      };

      if (bgCanvas && !initGalaxy(bgCanvas)) initSand(bgCanvas);

      // Shared canvas driver: draw only while on screen, capped at ~30fps.
      // Static frame when offscreen or under prefers-reduced-motion.
      const runCanvasLoop = (
        canvas: HTMLCanvasElement,
        resize: () => void,
        draw: (t: number) => void,
        staticT: number,
      ) => {
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        resize();
        draw(staticT);
        document.fonts.ready.then(() => draw(staticT));
        if (!reduced) {
          let raf = 0;
          let last = 0;
          const loop = (ms: number) => {
            raf = requestAnimationFrame(loop);
            if (ms - last < 33) return;
            last = ms;
            draw(ms / 1000);
          };
          new IntersectionObserver(([entry]) => {
            cancelAnimationFrame(raf);
            if (entry.isIntersecting) raf = requestAnimationFrame(loop);
          }).observe(canvas);
        }
        new ResizeObserver(() => {
          resize();
          draw(staticT);
        }).observe(canvas.parentElement as Element);
      };

      // How-it-works diagram: phone ⇄ desktop with packets streaming both ways
      // over the tunnel, and a dotted relay fallback path underneath.
      const arch = document.getElementById("arch-canvas") as HTMLCanvasElement | null;
      const archCtx = arch?.getContext("2d");
      if (arch && archCtx) {
        const C = {
          line: "rgba(255,255,255,0.22)",
          faint: "rgba(255,255,255,0.1)",
          text: "#f3f4f6",
          muted: "#8a8a90",
          dim: "#59595e",
          green: "#3dd68c",
          bg: "#090909",
        };
        const ctx = archCtx;
        let w = 0;
        let h = 0;
        const mono = (px: number) => `${px}px "IBM Plex Mono", monospace`;

        const resize = () => {
          const width = arch.parentElement?.getBoundingClientRect().width ?? 0;
          if (!width) return;
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          w = width;
          h = w < 640 ? 264 : w >= 1000 ? 360 : 290;
          arch.width = Math.round(w * dpr);
          arch.height = Math.round(h * dpr);
          arch.style.height = `${h}px`;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };

        // keep caption text inside the canvas on narrow screens
        const clampX = (x: number, text: string, px: number, maxW: number) => {
          ctx.font = mono(px);
          const half = ctx.measureText(text).width / 2 + 6;
          return Math.min(Math.max(x, half), maxW - half);
        };

        const label = (
          text: string,
          x: number,
          y: number,
          px: number,
          color: string,
          hash = false,
        ) => {
          ctx.font = mono(px);
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          if (hash) {
            const full = `# ${text}`;
            const start = x - ctx.measureText(full).width / 2;
            ctx.textAlign = "left";
            ctx.fillStyle = C.green;
            ctx.fillText("# ", start, y);
            ctx.fillStyle = color;
            ctx.fillText(text, start + ctx.measureText("# ").width, y);
            ctx.textAlign = "center";
          } else {
            ctx.fillStyle = color;
            ctx.fillText(text, x, y);
          }
        };

        // stacked multi-line badge, first line bright, rest muted
        const badge = (lines: string[], x: number, y: number, px: number) => {
          ctx.font = mono(px);
          const lh = px + 8;
          const tw = Math.max(...lines.map((l) => ctx.measureText(l).width));
          const bw = tw + 38;
          const bh = lines.length * lh + 22;
          ctx.fillStyle = C.bg;
          ctx.strokeStyle = C.line;
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.roundRect(x - bw / 2, y - bh / 2, bw, bh, 14);
          ctx.fill();
          ctx.stroke();
          const startY = y - ((lines.length - 1) * lh) / 2;
          lines.forEach((line, i) => {
            label(line, x, startY + i * lh, px, i === 0 ? C.text : C.muted);
          });
        };

        const drawPhone = (x: number, y: number, t: number, big: boolean) => {
          const pw = big ? 64 : 48;
          const ph = big ? 116 : 88;
          ctx.strokeStyle = C.line;
          ctx.lineWidth = 1.4;
          ctx.beginPath();
          ctx.roundRect(x - pw / 2, y - ph / 2, pw, ph, big ? 14 : 11);
          ctx.stroke();
          ctx.beginPath();
          ctx.moveTo(x - 9, y - ph / 2 + 11);
          ctx.lineTo(x + 9, y - ph / 2 + 11);
          ctx.stroke();
          // "screen": prompt + streamed lines that tick with time
          const ix = x - pw / 2 + (big ? 13 : 10);
          ctx.fillStyle = C.green;
          ctx.font = mono(big ? 14 : 11);
          ctx.textAlign = "left";
          ctx.fillText("❯", ix, y - ph / 2 + (big ? 38 : 30));
          ctx.fillStyle = C.dim;
          for (let i = 0; i < 4; i++) {
            const lw = (big ? 12 : 9) + ((Math.sin(t * 1.4 + i * 2.1) + 1) / 2) * (pw - (big ? 36 : 28));
            ctx.fillRect(ix, y - ph / 2 + (big ? 52 : 42) + i * (big ? 13 : 10), lw, big ? 2.5 : 2);
          }
        };

        const drawDesktop = (x: number, y: number, t: number, big: boolean) => {
          const mw = big ? 132 : 96;
          const mh = big ? 88 : 64;
          ctx.strokeStyle = C.line;
          ctx.lineWidth = 1.4;
          ctx.beginPath();
          ctx.roundRect(x - mw / 2, y - mh / 2, mw, mh, big ? 10 : 8);
          ctx.stroke();
          ctx.beginPath();
          ctx.moveTo(x, y + mh / 2);
          ctx.lineTo(x, y + mh / 2 + (big ? 14 : 10));
          ctx.moveTo(x - (big ? 24 : 16), y + mh / 2 + (big ? 14 : 10));
          ctx.lineTo(x + (big ? 24 : 16), y + mh / 2 + (big ? 14 : 10));
          ctx.stroke();
          const ix = x - mw / 2 + (big ? 15 : 11);
          ctx.fillStyle = C.green;
          ctx.font = mono(big ? 14 : 11);
          ctx.textAlign = "left";
          ctx.fillText("❯", ix, y - mh / 2 + (big ? 27 : 20));
          ctx.fillStyle = C.dim;
          for (let i = 0; i < 3; i++) {
            const lw = (big ? 24 : 16) + ((Math.sin(t * 1.7 + i * 1.3) + 1) / 2) * (mw - (big ? 62 : 44));
            ctx.fillRect(ix, y - mh / 2 + (big ? 40 : 30) + i * (big ? 15 : 11), lw, big ? 2.5 : 2);
          }
        };

        const draw = (t: number) => {
          ctx.clearRect(0, 0, w, h);
          // on wide screens, scale the whole drawing up instead of re-tuning sizes
          const s = w >= 1000 ? 1.3 : 1;
          ctx.save();
          ctx.scale(s, s);
          const vw = w / s;
          const big = vw >= 640;
          const vh = h / s;
          const topOffset = big ? 58 : 44;
          const bottomOffset = big ? 150 : 118;
          const midY = (vh + topOffset - bottomOffset) / 2;
          const px = big ? vw * 0.12 : vw * 0.15;
          const dx = big ? vw * 0.88 : vw * 0.85;
          const lineStart = px + (big ? 42 : 32);
          const lineEnd = dx - (big ? 78 : 56);

          // main tunnel line
          ctx.strokeStyle = C.line;
          ctx.lineWidth = 1.2;
          ctx.setLineDash([]);
          ctx.beginPath();
          ctx.moveTo(lineStart, midY);
          ctx.lineTo(lineEnd, midY);
          ctx.stroke();

          // endpoints pulse
          const pulse = (big ? 2.8 : 2.2) + Math.sin(t * 2.4) * 0.8;
          ctx.fillStyle = C.green;
          for (const ex of [lineStart, lineEnd]) {
            ctx.beginPath();
            ctx.arc(ex, midY, pulse, 0, Math.PI * 2);
            ctx.fill();
          }

          // packets: green → desktop (input), light ← phone (output)
          const span = lineEnd - lineStart;
          const packet = (p: number, color: string) => {
            const alpha = Math.min(1, Math.min(p, 1 - p) * 10);
            ctx.globalAlpha = alpha;
            ctx.fillStyle = color;
            ctx.beginPath();
            ctx.arc(lineStart + span * p, midY, big ? 3.4 : 2.6, 0, Math.PI * 2);
            ctx.fill();
            ctx.globalAlpha = 1;
          };
          for (let i = 0; i < 3; i++) packet((t * 0.16 + i / 3) % 1, C.green);
          for (let i = 0; i < 3; i++) packet(1 - ((t * 0.13 + i / 3 + 0.15) % 1), "#b9bac0");

          // direction labels, centered in the gaps between badge and endpoints
          const badgeLines = big
            ? ["Zedra Protocol", "QUIC/UDP (Iroh)", "TLS 1.3 end-to-end"]
            : ["Zedra Protocol", "QUIC · Iroh", "TLS 1.3 · E2E"];
          const badgePx = big ? 13.5 : 11;
          ctx.font = mono(badgePx);
          const badgeHalf = Math.max(...badgeLines.map((l) => ctx.measureText(l).width)) / 2 + 19;
          const center = lineStart + span / 2;
          const cw = vw;
          if (big) {
            label("keystrokes · approvals →", (lineStart + center - badgeHalf) / 2, midY - 22, 13, C.muted);
            label("← frames · files · diffs", (center + badgeHalf + lineEnd) / 2, midY + 26, 13, C.muted);
          }

          // relay fallback: dotted arc between the same endpoints, dipping
          // below the caption band (it crosses caption height only mid-span,
          // where no caption text sits)
          ctx.strokeStyle = C.faint;
          ctx.setLineDash([3, 5]);
          ctx.beginPath();
          ctx.moveTo(lineStart, midY + 6);
          ctx.quadraticCurveTo(cw / 2, midY + (big ? 150 : 118), lineEnd, midY + 6);
          ctx.stroke();
          ctx.setLineDash([]);
          const relayLines = ["relay", "blocked by sNAT or CGNAT", "E2E encrypted"];
          const relayPx = big ? 12.5 : 10.5;
          relayLines.forEach((line, i) => {
            label(
              line,
              cw / 2,
              midY + (big ? 78 : 110) + i * (relayPx + 6),
              relayPx,
              i === 0 ? C.muted : C.dim,
            );
          });

          // center badge sits on top of the line so packets "enter the tunnel"
          badge(badgeLines, center, midY, badgePx);

          // nodes + captions
          drawPhone(px, midY, t, big);
          drawDesktop(dx, midY, t, big);
          const capY = midY + (big ? 88 : 66);
          const kickPx = big ? 13 : 11;
          const titlePx = big ? 16 : 12;
          const phoneTitle = big ? "Zedra app: the UI" : "Zedra app · UI";
          const deskTitle = big ? "zedra daemon: the backend" : "daemon · backend";
          label("your phone", clampX(px, "# your phone", kickPx, vw), capY, kickPx, C.muted, true);
          label(phoneTitle, clampX(px, phoneTitle, titlePx, vw), capY + (big ? 24 : 19), titlePx, C.text);
          label("your desktop", clampX(dx, "# your desktop", kickPx, vw), capY, kickPx, C.muted, true);
          label(deskTitle, clampX(dx, deskTitle, titlePx, vw), capY + (big ? 24 : 19), titlePx, C.text);
          ctx.restore();
        };

        runCanvasLoop(arch, resize, draw, 2.2);
      }

      // Agents canvas: floating agent chips + notification/usage/history cards.
      const agents = document.getElementById("agents-canvas") as HTMLCanvasElement | null;
      const agentsCtx = agents?.getContext("2d");
      if (agents && agentsCtx) {
        const ctx = agentsCtx;
        const mono = (px: number) => `${px}px "IBM Plex Mono", monospace`;
        let w = 0;
        let h = 0;
        const resize = () => {
          const width = agents.parentElement?.getBoundingClientRect().width ?? 0;
          if (!width) return;
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          w = width;
          h = w < 560 ? 470 : 580;
          agents.width = Math.round(w * dpr);
          agents.height = Math.round(h * dpr);
          agents.style.height = `${h}px`;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };
        // real agent icons copied from the app (public/agents/*.svg, color baked)
        const icons: Record<string, HTMLImageElement> = {};
        for (const name of [
          "claude",
          "openai",
          "opencode",
          "hermesagent",
          "pi",
          "cursor",
          "geminicli",
          "githubcopilot",
          "openclaw",
        ]) {
          const img = new Image();
          img.src = `/agents/${name}.svg`;
          icons[name] = img;
        }
        // aspect-fit so icons with non-square viewBoxes stay balanced
        const drawIcon = (img: HTMLImageElement | undefined, x: number, y: number, size: number) => {
          if (!img?.complete || !img.naturalWidth) return;
          const r = img.naturalWidth / img.naturalHeight;
          const dw = r >= 1 ? size : size * r;
          const dh = r >= 1 ? size / r : size;
          ctx.drawImage(img, x + (size - dw) / 2, y + (size - dh) / 2, dw, dh);
        };
        // cards cluster in the center; chips orbit the edges and may overlap
        const chips = [
          { name: "Claude Code", ic: "claude", x: 0.16, y: 0.06, ph: 0.4, sp: 1.0 },
          { name: "Codex", ic: "openai", x: 0.5, y: 0.03, ph: 2.2, sp: 0.8 },
          { name: "Gemini", ic: "geminicli", x: 0.85, y: 0.08, ph: 5.1, sp: 1.1 },
          { name: "OpenCode", ic: "opencode", x: 0.1, y: 0.36, ph: 4.1, sp: 1.2 },
          { name: "Cursor", ic: "cursor", x: 0.91, y: 0.33, ph: 1.2, sp: 0.9 },
          { name: "Hermes", ic: "hermesagent", x: 0.09, y: 0.66, ph: 3.1, sp: 0.9 },
          { name: "Pi", ic: "pi", x: 0.92, y: 0.6, ph: 1.6, sp: 1.1 },
          { name: "Copilot", ic: "githubcopilot", x: 0.24, y: 0.88, ph: 3.7, sp: 1.0 },
          { name: "OpenClaw", ic: "openclaw", x: 0.72, y: 0.87, ph: 2.6, sp: 0.8 },
        ];
        const box = (x: number, y: number, bw: number, bh: number, r: number) => {
          ctx.fillStyle = "#111112";
          ctx.strokeStyle = "rgba(255,255,255,0.14)";
          ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.roundRect(x, y, bw, bh, r);
          ctx.fill();
          ctx.stroke();
        };
        const kicker = (text: string, x: number, y: number, t: number, ph: number) => {
          const blink = 0.5 + 0.5 * Math.sin(t * 2.6 + ph);
          ctx.fillStyle = `rgba(61,214,140,${0.35 + 0.65 * blink})`;
          ctx.beginPath();
          ctx.arc(x, y, 3, 0, Math.PI * 2);
          ctx.fill();
          ctx.font = mono(11);
          ctx.fillStyle = "#59595e";
          ctx.fillText(text, x + 10, y + 0.5);
        };
        // mirrors the app's usage_bar_color thresholds
        const gaugeColor = (pct: number) =>
          pct < 60 ? "#3dd68c" : pct < 85 ? "#e0af68" : "#f7768e";
        // app gauge row: `5h [████] 63%  1h20m`
        const gauge = (x: number, y: number, lab: string, pct: number, reset: string) => {
          ctx.font = mono(10.5);
          ctx.fillStyle = "#59595e";
          ctx.fillText(lab, x, y);
          const bx = x + 24;
          const bw = 66;
          ctx.fillStyle = "rgba(255,255,255,0.12)";
          ctx.beginPath();
          ctx.roundRect(bx, y - 2, bw, 4, 2);
          ctx.fill();
          ctx.fillStyle = gaugeColor(pct);
          ctx.beginPath();
          ctx.roundRect(bx, y - 2, (bw * pct) / 100, 4, 2);
          ctx.fill();
          ctx.fillStyle = "#c9cacd";
          ctx.fillText(`${pct}%`, bx + bw + 10, y);
          ctx.fillStyle = "#59595e";
          ctx.fillText(reset, bx + bw + 46, y);
        };
        const bob = (t: number, sp: number, ph: number) => ({
          dx: Math.cos(t * sp * 0.5 + ph) * 6,
          dy: Math.sin(t * sp + ph) * 7,
        });
        const draw = (t: number) => {
          ctx.clearRect(0, 0, w, h);
          // shrink the whole cluster on narrow screens: cards + chips use fixed
          // pixel sizes, so scale the drawing down (and lay it out in a larger
          // virtual space) instead of letting them overlap at phone widths.
          const s = Math.max(0.7, Math.min(1, w / 560));
          ctx.save();
          ctx.scale(s, s);
          const vw = w / s;
          const vh = h / s;
          ctx.textAlign = "left";
          ctx.textBaseline = "middle";

          // notification card — real hook format: `{agent} requires approval`
          // as title, the session/chat title as body (agent_hook_recv.rs)
          {
            const { dx, dy } = bob(t, 0.7, 0.9);
            const bw = 262;
            let cx = 0.42 * vw - bw / 2 + dx;
            cx = Math.min(Math.max(cx, 4), vw - bw - 4);
            const cy = 0.15 * vh + dy;
            box(cx, cy, bw, 78, 14);
            kicker("notification", cx + 18, cy + 18, t, 0.9);
            ctx.font = mono(12.5);
            ctx.fillStyle = "#c9cacd";
            ctx.fillText("Claude Code requires approval", cx + 16, cy + 40);
            ctx.font = mono(11.5);
            ctx.fillStyle = "#8a8a90";
            ctx.fillText("Add QR pairing to onboarding", cx + 16, cy + 58);
          }

          // usage card: the app's agent card with rate-limit gauges
          {
            const { dx, dy } = bob(t, 0.9, 2.7);
            const bw = 256;
            let cx = 0.6 * vw - bw / 2 + dx;
            cx = Math.min(Math.max(cx, 4), vw - bw - 4);
            const cy = 0.32 * vh + dy;
            box(cx, cy, bw, 128, 14);
            drawIcon(icons.claude, cx + 16, cy + 14, 18);
            ctx.font = mono(13);
            ctx.fillStyle = "#f3f4f6";
            ctx.fillText("Claude Code", cx + 42, cy + 23.5);
            // plan badge next to the name, like the app's agent card
            const nameW = ctx.measureText("Claude Code").width;
            ctx.font = mono(10.5);
            const planW = ctx.measureText("max").width + 12;
            ctx.strokeStyle = "rgba(255,255,255,0.14)";
            ctx.fillStyle = "#151517";
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.roundRect(cx + 42 + nameW + 10, cy + 14, planW, 19, 10);
            ctx.fill();
            ctx.stroke();
            ctx.fillStyle = "#8a8a90";
            ctx.fillText("max", cx + 42 + nameW + 16, cy + 24);
            gauge(cx + 16, cy + 52, "5h", 63, "1h20m");
            gauge(cx + 16, cy + 76, "7d", 41, "3d 2h");
            ctx.font = mono(10.5);
            ctx.fillStyle = "#59595e";
            ctx.fillText("+412 / -96 lines changed", cx + 16, cy + 104);
          }

          // history card: unified session list across agents
          {
            const { dx, dy } = bob(t, 0.8, 4.6);
            const bw = 292;
            let cx = 0.44 * vw - bw / 2 + dx;
            cx = Math.min(Math.max(cx, 4), vw - bw - 4);
            let cy = 0.57 * vh + dy;
            const rows = [
              { ic: "claude", title: "Fix terminal resume race", meta: "2h ago" },
              { ic: "openai", title: "Refactor auth flow", meta: "5h ago" },
              { ic: "opencode", title: "Landing page SEO pass", meta: "1d ago" },
            ];
            const bh = 36 + rows.length * 32 + 6;
            cy = Math.min(cy, vh - bh - 4);
            box(cx, cy, bw, bh, 14);
            kicker("history: tap to resume", cx + 18, cy + 18, t, 4.6);
            rows.forEach((r, i) => {
              const ry = cy + 48 + i * 32;
              drawIcon(icons[r.ic], cx + 16, ry - 8, 16);
              ctx.font = mono(12);
              ctx.fillStyle = "#c9cacd";
              ctx.fillText(r.title, cx + 42, ry);
              ctx.font = mono(10.5);
              ctx.fillStyle = "#59595e";
              ctx.textAlign = "right";
              ctx.fillText(r.meta, cx + bw - 14, ry);
              ctx.textAlign = "left";
            });
          }

          // chips last: agents float on top of the feature cards
          for (const c of chips) {
            ctx.font = mono(13);
            const tw = ctx.measureText(c.name).width;
            const bw = 16 + 28 + tw + 16;
            const bh = 44;
            let cx = c.x * vw - bw / 2 + Math.cos(t * c.sp * 0.6 + c.ph) * 7;
            let cy = c.y * vh + Math.sin(t * c.sp + c.ph) * 8;
            cx = Math.min(Math.max(cx, 4), vw - bw - 4);
            cy = Math.min(Math.max(cy, 4), vh - bh - 4);
            box(cx, cy, bw, bh, 22);
            drawIcon(icons[c.ic], cx + 14, cy + bh / 2 - 10, 20);
            ctx.font = mono(13);
            ctx.fillStyle = "#f3f4f6";
            ctx.fillText(c.name, cx + 42, cy + bh / 2 + 0.5);
          }
          ctx.restore();
        };
        // Repaint the static frame when each icon finishes loading, so chips/cards
        // aren't icon-less under prefers-reduced-motion if SVGs arrive late.
        for (const img of Object.values(icons)) img.addEventListener("load", () => draw(1.1));
        runCanvasLoop(agents, resize, draw, 1.1);
      }

      // Revolution canvas: GPU-waveform bars + drifting tech ticker.
      const rev = document.getElementById("rev-canvas") as HTMLCanvasElement | null;
      const revCtx = rev?.getContext("2d");
      if (rev && revCtx) {
        const ctx = revCtx;
        const mono = (px: number) => `${px}px "IBM Plex Mono", monospace`;
        let w = 0;
        let h = 0;
        const resize = () => {
          const width = rev.parentElement?.getBoundingClientRect().width ?? 0;
          if (!width) return;
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          w = width;
          h = 220;
          rev.width = Math.round(w * dpr);
          rev.height = Math.round(h * dpr);
          rev.style.height = `${h}px`;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        };
        const words = [
          { t: "GPUI", green: true, y: 0.2, sp: 26, off: 0 },
          { t: "Metal", green: false, y: 0.34, sp: 20, off: 300 },
          { t: "wgpu", green: false, y: 0.14, sp: 32, off: 620 },
          { t: "Vulkan", green: false, y: 0.82, sp: 24, off: 150 },
          { t: "iroh", green: true, y: 0.68, sp: 18, off: 480 },
          { t: "QUIC/UDP", green: false, y: 0.9, sp: 28, off: 800 },
          { t: "TLS 1.3", green: false, y: 0.26, sp: 22, off: 1040 },
          { t: "no webview", green: true, y: 0.76, sp: 30, off: 240 },
        ];
        const draw = (t: number) => {
          ctx.clearRect(0, 0, w, h);
          const midY = h / 2;
          for (let x = 4; x < w; x += 8) {
            const a = Math.sin(x * 0.012 + t * 1.5) * Math.sin(x * 0.0042 - t * 0.55);
            const amp = 8 + Math.abs(a) * (h * 0.36);
            const isGreen = Math.floor(x / 8) % 9 === 0;
            ctx.fillStyle = isGreen
              ? `rgba(61,214,140,${0.25 + Math.abs(a) * 0.5})`
              : `rgba(255,255,255,${0.08 + Math.abs(a) * 0.14})`;
            ctx.fillRect(x, midY - amp, 3, amp * 2);
          }
          ctx.textAlign = "left";
          ctx.textBaseline = "middle";
          ctx.font = mono(12.5);
          for (const wd of words) {
            const tw = ctx.measureText(wd.t).width;
            const travel = w + tw + 120;
            const x = w + 60 - ((t * wd.sp + wd.off) % travel);
            ctx.fillStyle = wd.green ? "rgba(61,214,140,0.75)" : "rgba(185,186,192,0.6)";
            ctx.fillText(wd.t, x, wd.y * h);
          }
        };
        runCanvasLoop(rev, resize, draw, 3.7);
      }

      // Center the sticky demo frame in the current viewport by computing
      // its actual top offset (viewport height minus frame height, halved)
      // instead of a fixed px or the height:100vh+flex-center trick — see
      // the CSS comment on .scrolly-demo for why those two failed.
      {
        const demoWrap = document.querySelector<HTMLElement>(".scrolly-demo");
        const frame = document.querySelector<HTMLElement>(".demo-frame");
        if (demoWrap && frame) {
          const recenter = () => {
            const h = frame.getBoundingClientRect().height;
            const top = Math.max(24, (window.innerHeight - h) / 2);
            demoWrap.style.top = `${top}px`;
          };
          recenter();
          window.addEventListener("resize", recenter, { passive: true });
        }
      }

      // Scrolly: activate whichever step's center is nearest the sticky
      // demo's own vertical center (not the viewport's) — the demo is the
      // fixed reference the reader's eye stays on, so a step should focus
      // exactly when it lines up with the demo's half-height, not some
      // viewport-relative point that drifts as the demo's sticky offset,
      // header height, etc. change. Falls back to viewport center on mobile
      // where the demo is hidden (rect collapses to zero height there).
      const steps = [...document.querySelectorAll<HTMLElement>(".scrolly-step")];
      const slides = [...document.querySelectorAll<HTMLElement>(".demo-slide")];
      const demoEl = document.querySelector<HTMLElement>(".scrolly-demo");
      if (steps.length) {
        let activeStep = -1;
        const activate = (index: number) => {
          if (index === activeStep) return;
          activeStep = index;
          steps.forEach((el, i) => el.classList.toggle("active", i === index));
          slides.forEach((el, i) => el.classList.toggle("active", i === index));
        };
        const pickNearest = () => {
          const demoRect = demoEl?.getBoundingClientRect();
          const target =
            demoRect && demoRect.height > 0
              ? demoRect.top + demoRect.height / 2
              : window.innerHeight / 2;
          let best = 0;
          let bestDist = Infinity;
          steps.forEach((el, i) => {
            const rect = el.getBoundingClientRect();
            const dist = Math.abs(rect.top + rect.height / 2 - target);
            if (dist < bestDist) {
              bestDist = dist;
              best = i;
            }
          });
          activate(best);
        };
        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            pickNearest();
            ticking = false;
          });
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll, { passive: true });
        pickNearest();
      }

      // Scroll-reveal: add .is-visible once a [data-reveal] block enters the
      // viewport. Trigger a touch above the bottom edge so content is already
      // animating by the time it's visible. Reduced-motion users keep content
      // visible via the CSS guard (no transition there), so this observer is
      // a no-op visually for them — but we still flip the class so the state
      // matches if they later toggle motion off mid-session.
      {
        const reveals = document.querySelectorAll<HTMLElement>("[data-reveal]");
        if (reveals.length) {
          const io = new IntersectionObserver(
            (entries, obs) => {
              for (const entry of entries) {
                if (!entry.isIntersecting) continue;
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            },
            { rootMargin: "0px 0px -10% 0px", threshold: 0.12 },
          );
          reveals.forEach((el) => io.observe(el));
        }
      }

      document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const installBlock = btn.closest(
            ".install-block",
          ) as HTMLElement | null;
          const text = installBlock?.dataset.copy ?? "";
          try {
            await navigator.clipboard.writeText(text);
            btn.innerHTML = CHECK_ICON;
            setTimeout(() => {
              btn.innerHTML = COPY_ICON;
            }, 1500);
          } catch {}
        });
      });
    </script>
  </body>
</html>
