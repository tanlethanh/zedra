// How-it-works: name the client/server split, then demystify by negation.
// The diagram itself is drawn on <canvas id="arch-canvas"> (see script below).
const howRows = [
  {
    title: "Pair once",
    body: "Scan a QR code once to register public keys on both devices. After that, reconnects use PKI auth without another QR.",
  },
  {
    title: "Stream the workspace",
    body: "A tailored, end-to-end encrypted protocol multiplexes terminal frames, files, diffs, and control messages on demand.",
  },
  {
    title: "Reconnect anywhere",
    body: "Leave Wi-Fi or switch networks. Zedra redials the same machine, and your sessions persist across reconnects.",
  },
];

const techPillars = [
  {
    title: "Agent neutral",
    body: "Bring any agent. Terminal agents work by default; first-class integrations add notifications, usage, history, and code mentions.",
  },
  {
    title: "P2P by default",
    body: "Direct by default over outbound-only QUIC/UDP. End-to-end encrypted, with relay fallback when networks block the path.",
  },
  {
    title: "GPUI on mobile",
    body: "Zed's GPUI on mobile, built for high-performance code editing and terminal rendering without a webview.",
  },
  {
    title: "Open toolbox",
    body: "MIT-licensed, inspectable, and customizable enough to become part of your own developer toolbox.",
  },
];

const faqItems = [
  {
    q: "Which coding agents does Zedra support?",
    a: "First-class setup exists for Claude Code, Codex, OpenCode, Pi, and Hermes. Anything that runs in a terminal also runs in Zedra.",
  },
  {
    q: "Do I need a VPN or port forwarding?",
    a: "No. Pair by QR once; Zedra connects directly when possible and uses an encrypted relay when blocked. Tailscale works too, as one extra WireGuard layer with some latency cost.",
  },
  {
    q: "Is my code sent to a cloud server?",
    a: "No. Your code and agents stay on your machine. Relays only forward encrypted packets they cannot read.",
  },
  {
    q: "How is Zedra different from an SSH app?",
    a: "SSH gives you a terminal. Zedra adds the workspace around it: files, editor, diffs, markdown preview, and push notifications. See zedra.dev/compare.",
  },
  {
    q: "Is Zedra free?",
    a: "Yes. Zedra is free and open source today. Hosted conveniences may become paid later; the core workspace stays free.",
  },
  {
    q: "What happens when I lose connection?",
    a: "Sessions live on your machine. Zedra reconnects, restores the terminal backlog, and picks up where you left off.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: { "@type": "Answer", text: item.a.replace(/`/g, "") },
  })),
};

const pageTitle = "Zedra — Remote control for AI coding agents";
const pageDescription =
  "Remote control for AI coding agents, with a dev workspace on your phone: terminal, editor, markdown, and git diff. Pair by QR for a direct encrypted tunnel. No VPN.";
const canonicalUrl = "https://zedra.dev/";
