// Each feature drives one demo slide in the scrolly panel.
// Demo captions are placeholders until real device captures land.
// Icons are inline Lucide SVGs (stroke, currentColor).
const lucide = (paths: string) =>
  `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${paths}</svg>`;

