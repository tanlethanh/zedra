                        src={feature.demoImg}
                        alt={feature.title}
                        loading="lazy"
                        decoding="async"
                        formats={demoImageFormats}
                        fallbackFormat="png"
                        widths={demoImageWidths}
                        sizes={demoImageSizes}
                        quality={demoImageQuality}
                      />
