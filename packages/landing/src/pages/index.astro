    <script is:inline>
      // Mark JS available synchronously so the scroll-reveal CSS can hide
      // pre-reveal content before first paint, with no flash, and without
      // risk of leaving it invisible if the late body script fails to run.
      document.documentElement.classList.add("js");
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Zedra",
        description: pageDescription,
        url: canonicalUrl,
        applicationCategory: "DeveloperApplication",
        operatingSystem: "iOS, Android",
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
        author: { "@id": "https://zedra.dev/#organization" },
        publisher: { "@id": "https://zedra.dev/#organization" },
        sameAs: [
          "https://github.com/tanlethanh/zedra",
          "https://x.com/zedradev",
          "https://discord.gg/39MmkSS8sc",
          "https://apps.apple.com/app/zedra-code-from-anywhere/id6760534630",
          "https://play.google.com/store/apps/details?id=dev.zedra.app",
        ],
      })}
    />
    {baseSchemas.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Lora:wght@400&display=swap");

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --bg: #090909;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --text: #f3f4f6;
        --text-secondary: #c2c2c8;
        --muted: #59595e;
        --green: #3dd68c;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        color: var(--text);
        font-family: "IBM Plex Mono", "SF Mono", "Fira Code", monospace;
      }

      /* bg lives on html only: an opaque body background would paint over
         the fixed z-index:-1 shader canvas */
      html {
        background: var(--bg);
      }

      body {
        padding: 32px 32px 0px;
      }

      /* Smooth in-page anchor jumps only when the user opts into motion. */
      @media (prefers-reduced-motion: no-preference) {
        html {
          scroll-behavior: smooth;
        }
      }

      /* Scroll-reveal: blocks fade + lift in as they enter the viewport.
         Reduced-motion users see content immediately with no transition.
         Gated on .js (set synchronously in <head> below) so content stays
         visible if scripts fail to load. */
      @media (prefers-reduced-motion: no-preference) {
        html.js [data-reveal] {
          opacity: 0;
          transform: translateY(16px);
          transition:
            opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
          transition-delay: var(--reveal-delay, 0ms);
          will-change: opacity, transform;
        }

        html.js [data-reveal].is-visible {
          opacity: 1;
          transform: none;
        }
      }

      /* dim animated shader backdrop; sits behind the page content */
      #bg-shader {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: -1;
        pointer-events: none;
      }

      .page {
        max-width: 1280px;
        margin: 0 auto;
        min-height: calc(100vh - 32px);
        display: flex;
        flex-direction: column;
        gap: 32px;
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        color: var(--text);
        text-decoration: none;
        font-size: 28px;
        font-weight: 400;
        letter-spacing: 0.02em;
        font-family: "Lora", Georgia, serif;
      }

      .logo-icon {
        width: 32px;
        height: 40px;
        flex-shrink: 0;
      }

      .logo span {
        color: var(--green);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
        gap: 32px;
        align-items: stretch;
        min-height: calc(100vh - 96px);
      }

      /* --- content sections below the hero ---
         Idiom: hairline rules + whitespace, no filled cards. Section
         markers read as terminal comments; h2 uses the logo serif. */

      /* sections share the hero's full content width (.page max-width) */
      .section {
        display: grid;
        gap: 20px;
        padding: 112px 0 80px;
        border-top: 1px solid var(--border);
        width: 100%;
      }

      .section-label {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
      }

      .section-label::before {
        content: "# ";
      }

      .section h2 {
        margin: 0;
        font-family: "Lora", Georgia, serif;
        font-weight: 400;
        font-size: clamp(32px, 4vw, 44px);
        line-height: 1.15;
        letter-spacing: 0.01em;
      }

      .section > p,
      .section .lede {
        margin: 0;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.75;
        max-width: 700px;
      }

      /* centered section variant (how-it-works) */
      .section-center {
        justify-items: center;
        text-align: center;
      }

      .section-center > p,
      .section-center .lede {
        margin: 0 auto;
      }

      /* generic two-column: text | visual */
      .two-col {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 64px;
        align-items: center;
      }

      .two-col .col-text {
        display: grid;
        gap: 20px;
        align-content: start;
      }

      .two-col canvas {
        display: block;
        width: 100%;
      }

      .section a {
        color: var(--text);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--muted);
      }

      .section a:hover {
        text-decoration-color: var(--text);
      }

      .agent-notes {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 10px;
        max-width: 640px;
      }

      .agent-notes li {
        position: relative;
        padding-left: 22px;
        color: var(--muted);
        font-size: 14.5px;
        line-height: 1.7;
      }

      /* lighter body copy for the agents section specifically */
      section[aria-labelledby="agents-heading"] .lede,
      section[aria-labelledby="agents-heading"] .agent-notes li {
        color: var(--text-secondary);
      }

      .agent-notes li::before {
        content: "#";
        position: absolute;
        left: 0;
        color: var(--green);
      }

      .agents-row {
        display: flex;
        flex-wrap: wrap;
        column-gap: 8px;
        row-gap: 6px;
        margin: 0;
        padding: 0;
        list-style: none;
        font-size: 15px;
      }

      .agents-row li + li::before {
        content: "/";
        color: var(--muted);
        margin-right: 8px;
      }

      .agents-row a {
        text-decoration: none;
        color: var(--text);
        border-bottom: 1px solid var(--border-strong);
        padding-bottom: 1px;
      }

      .agents-row a:hover {
        border-bottom-color: var(--text);
      }

      .agents-row .agent-plain {
        color: var(--muted);
      }

      /* scrolly: big sticky demo on the left, header + feature steps right */
      .scrolly {
        display: grid;
        grid-template-columns: minmax(320px, 45%) minmax(0, 1fr);
        gap: 64px;
        align-items: start;
        width: 100%;
        margin-top: 8px;
        /* section-center (parent) centers text; feature copy reads left.
           (justify-items:start here would collapse the two columns below
           to their content width instead of stretching — width:100% above
           already neutralizes the parent's centering for .scrolly itself.) */
        text-align: left;
      }

      /* compact header above the feature steps */
      .ws-head {
        display: grid;
        gap: 10px;
        padding: 8px 0;
      }

      .ws-head h2 {
        font-size: clamp(28px, 3vw, 38px);
      }

      .ws-head .lede {
        font-size: 16px;
      }

      .scrolly-steps {
        display: grid;
      }

      .scrolly-step {
        display: grid;
        gap: 14px;
        align-content: center;
        min-height: 700px;
        padding: 26px 0;
        opacity: 0.3;
        transition: opacity 0.3s;
      }

      .scrolly-step:first-child {
        border-top: none;
        /* small extra runway before/after first and last step */
        margin-top: 60px;
      }

      .scrolly-step:last-child {
        margin-bottom: 60px;
      }

      .scrolly-step.active {
        opacity: 1;
      }

      /* Eased step activation: active steps settle in with a small lift,
         inactive ones recede slightly. Reduced-motion keeps the original
         opacity-only crossfade. */
      @media (prefers-reduced-motion: no-preference) {
        .scrolly-step {
          transition:
            opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
          transform: translateY(10px);
        }

        .scrolly-step.active {
          transform: none;
        }

        /* Feature text entering: when a step activates, its title and body
           slide + fade in with a small stagger. Inactive steps' text sits
           dimmed and offset until the step is focused. */
        .scrolly-step .step-title,
        .scrolly-step > p {
          opacity: 0;
          transform: translateY(8px);
          transition:
            opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        }

        .scrolly-step .step-title {
          transition-delay: 0.08s;
        }

        .scrolly-step > p {
          transition-delay: 0.16s;
        }

        .scrolly-step.active .step-title,
        .scrolly-step.active > p {
          opacity: 1;
          transform: none;
        }
      }

      .step-title {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .step-title :global(svg) {
        width: 26px;
        height: 26px;
        flex: none;
        color: var(--green);
      }

      .scrolly-step h3 {
        margin: 0;
        font-family: "Lora", Georgia, serif;
        font-weight: 400;
        font-size: clamp(24px, 2.6vw, 30px);
        letter-spacing: 0.01em;
      }

      .scrolly-step p {
        margin: 0;
        color: var(--text-secondary);
        font-size: 16px;
        line-height: 1.75;
        max-width: 520px;
      }

      /* per-step screenshot: hidden on desktop (the sticky demo shows it);
         revealed inline under each step on narrow screens where the sticky
         demo column is display:none. */
      .step-img {
        display: none;
      }

      /* sticky at viewport center. NOTE: top:50% + translateY(-50%) looks
         like the standard centering trick but is wrong here — the
         translateY applies unconditionally, even before the element is
         actually stuck (while it's still in normal flow near the top of
         its own section), permanently dragging it up by half its own
         height into whatever content sits above the section. Pin the box
         to the viewport with top:0 + height:100vh instead, and center the
         content inside it with flexbox — no transform, no premature shift. */
      /* Fixed top offset, not a height:100vh + flex-center box. The
         100vh-box-with-centered-content trick only looks centered-in-
         viewport once sticky has actually pinned top:0 to the viewport
         edge. Before that engages — while this box is still in normal
         flow, sharing the initial viewport with the non-sticky header
         above it — the box centers content relative to its OWN top
         (below the header), so the phone rendered far down inside the
         visible slice. Not a spacing bug; a mismatch between the
         technique and having non-sticky content above it. A plain fixed
         offset has no such transitional state. */
      /* top is computed in JS to actually center the frame in the current
         viewport (see scroll script below) — a fixed px looks fine on a
         laptop screen but sits near the top with dead space below it on
         a tall monitor; a height:100vh + flex-center box centers exactly
         while stuck, but centers relative to its OWN top while still in
         normal flow (before sticky engages), which — since it shares the
         initial viewport with the non-sticky header above it — rendered
         the phone far down with a large dead gap above it. Computing the
         exact top offset needed for viewport-centering and applying it as
         a plain sticky offset avoids both failure modes. This value is
         the fallback before JS runs.
      */
      .scrolly-demo {
        position: sticky;
        top: 100px;
      }

      /* no fake device bezel — captures already carry their own chrome.
         aspect-ratio matches the widest current capture (manage-agents-2,
         1372x1921) so images show uncropped; widened + more flexible so it
         scales with the column instead of pinning to a narrow phone shape. */
      .demo-frame {
        position: relative;
        aspect-ratio: 1372 / 1921;
        width: 100%;
        max-width: 680px;
        margin: 0 auto;
        overflow: hidden;
      }

      .demo-slide {
        position: absolute;
        inset: 0;
        display: grid;
        align-content: center;
        justify-items: center;
        gap: 8px;
        padding: 20px;
        text-align: center;
        opacity: 0;
        transition: opacity 0.35s;
      }

      .demo-slide.active {
        opacity: 1;
      }

      /* Eased slide crossfade: the active capture eases in with a faint
         settle, inactive ones drift back. Reduced-motion falls back to the
         plain opacity crossfade above. */
      @media (prefers-reduced-motion: no-preference) {
        .demo-slide {
          transition:
            opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1),
            transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
          transform: scale(0.985);
        }

        .demo-slide.active {
          transform: none;
        }
      }

      /* real device captures fill the frame edge-to-edge, no padding.
         align-content/justify-items:center (inherited above) sizes a grid
         item to its own content instead of stretching it — override to
         stretch or the image renders smaller than the frame with visible
         gaps around it. */
      .demo-slide.has-img {
        padding: 0;
        gap: 0;
        align-content: stretch;
        justify-items: stretch;
      }

      .demo-slide.has-img picture,
      .demo-slide.has-img img {
        width: 100%;
        height: 100%;
        display: block;
      }

      .demo-slide.has-img img {
        /* contain, not cover: all slides share one frame box but each
           capture has its own native aspect ratio — cover cropped whatever
           didn't match (cut straight through the keyboard on the terminal
           shot). Contain always shows the full image; empty space reveals
           the cosmic background instead of clipping content. */
        object-fit: contain;
        object-position: center;
      }

      .demo-label {
        font-size: 13px;
        line-height: 1.6;
        color: var(--text);
      }

      .demo-label::before {
        content: "# ";
        color: var(--green);
      }

      .demo-caption {
        font-size: 12px;
        color: var(--muted);
      }

      #rev-canvas {
        display: block;
        width: 100%;
      }

      /* how-it-works breakdown table */
      .how-table {
        width: 100%;
        max-width: 720px;
        border-collapse: collapse;
        text-align: left;
        margin-top: 8px;
      }

      .how-table th {
        width: 220px;
        padding: 12px 28px 12px 0;
        font-size: 15px;
        font-weight: 500;
        vertical-align: top;
        border-top: 1px solid var(--border);
      }

      .how-table td {
        padding: 12px 0;
        color: var(--muted);
        font-size: 14.5px;
        line-height: 1.55;
        border-top: 1px solid var(--border);
      }

      .how-table tr:first-child th,
      .how-table tr:first-child td {
        border-top: none;
      }

      .section > p.how-links {
        font-size: 14px;
      }

      .feature-list {
        display: grid;
      }

      .feature-row {
        display: grid;
        grid-template-columns: 220px 1fr;
        gap: 24px;
        padding: 14px 0;
        border-top: 1px solid var(--border);
      }

      .feature-row:first-child {
        border-top: none;
        padding-top: 0;
      }

      .feature-row h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 500;
      }

      .feature-row p {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.7;
        max-width: 600px;
      }

      /* how-it-works animated diagram: phone ⇄ tunnel ⇄ desktop on canvas */
      section[aria-labelledby="how-heading"] {
        gap: 12px;
      }

      .arch-wrap {
        width: 100%;
        margin: 0 0 4px;
      }

      .arch-wrap canvas {
        display: block;
        width: 100%;
        color: var(--muted);
        font-size: 14px;
      }

      .faq-list {
        display: grid;
        max-width: 900px;
      }

      .faq-list details {
        border-top: 1px solid var(--border);
      }

      .faq-list details:first-child {
        border-top: none;
      }

      .faq-list summary {
        cursor: pointer;
        font-size: 16px;
        padding: 20px 0;
        list-style: none;
        display: flex;
        align-items: baseline;
        gap: 12px;
      }

      .faq-list summary::-webkit-details-marker {
        display: none;
      }

      .faq-list summary::before {
        content: "+";
        color: var(--muted);
        flex-shrink: 0;
      }

      .faq-list details[open] summary::before {
        content: "−";
      }

      .faq-list summary:hover {
        color: var(--green);
      }

      .faq-list p {
        margin: 0;
        padding: 0 0 22px 30px;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.75;
        max-width: 780px;
      }

      @media (max-width: 900px) {
        .feature-row {
          grid-template-columns: 1fr;
          gap: 6px;
        }

        /* no sticky demo on small screens; steps read as a plain list */
        .scrolly {
          grid-template-columns: 1fr;
        }

        .scrolly-demo {
          display: none;
        }

        .scrolly-step {
          min-height: 0;
          padding: 20px 0;
          opacity: 1;
        }

        /* On mobile, steps read as a plain list — undo the desktop entering
           effect so all step text is visible regardless of .active state. */
        .scrolly-step .step-title,
        .scrolly-step > p {
          opacity: 1;
          transform: none;
          transition: none;
          transition-delay: 0s;
        }

        .step-img {
          display: block;
          width: 100%;
          max-width: 460px;
          height: auto;
          margin-top: 4px;
          border-radius: 12px;
        }

        .ws-head {
          padding: 0 0 8px;
        }

        .two-col {
          grid-template-columns: 1fr;
          gap: 32px;
        }

        .how-table th {
          width: auto;
          display: block;
          padding: 18px 0 4px;
        }

        .how-table td {
          display: block;
          padding: 0 0 18px;
          border-top: none;
        }

        .how-table tr {
          display: block;
          border-top: 1px solid var(--border);
        }

        .how-table tr:first-child {
          border-top: none;
        }
      }

      .left {
        min-width: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 40px;
        max-width: 600px;
      }

      .hero-copy {
        display: grid;
        gap: 18px;
      }

      .hero-intro {
        display: grid;
        gap: 20px;
      }

      h1 {
        margin: 0;
        max-width: 10ch;
        font-size: 72px;
        line-height: 0.96;
        letter-spacing: -0.05em;
      }

      .description {
        margin: 0;
        max-width: 620px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.75;
      }

      .install-widget {
        display: flex;
        flex-direction: column;
        gap: 12px;
        height: 100%;
        max-height: 380px;
      }

      .tab-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }

      /* --- install card (terminal widget) --- */

      .install-card {
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: #111112;
        height: 220px;
      }

      .tab-list {
        display: flex;
        flex-wrap: nowrap;
        gap: 10px;
        overflow-x: auto;
        overflow-y: hidden;
        padding: 4px 14px 0;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }

      .tab-list::-webkit-scrollbar {
        display: none;
      }

      .tab-label {
        display: inline-flex;
        flex: 0 0 auto;
        align-items: center;
        gap: 8px;
        padding: 7px 2px 9px;
        border: none;
        border-bottom: 1px solid transparent;
        background: transparent;
        color: var(--muted);
        font-size: 12px;
        white-space: nowrap;
        cursor: pointer;
        transition:
          color 0.18s,
          border-color 0.18s;
      }

      .tab-label:hover {
        color: var(--text);
        border-bottom-color: rgba(255, 255, 255, 0.3);
      }

      :global(.tab-icon) {
        width: 15px;
        height: 15px;
        flex-shrink: 0;
      }

      .tab-panel {
        display: none;
      }

      .tab-panels {
        padding: 14px;
      }

      .terminal-code {
        display: grid;
        gap: 10px;
        font-size: 14px;
        line-height: 1.4;
      }

      .install-block {
        position: relative;
        display: grid;
        gap: 2px;
      }

      .terminal-comment {
        color: var(--muted);
      }

      .terminal-command {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .copy-btn {
        position: absolute;
        top: 0;
        right: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--muted);
        opacity: 0;
        transition:
          opacity 0.15s,
          color 0.15s;
      }

      .install-block:hover .copy-btn,
      .install-block:focus-within .copy-btn {
        opacity: 1;
      }

      .copy-btn:hover,
      .copy-btn:focus-visible {
        color: var(--text);
      }

      /* checked-tab state (CSS-only tabs) */

      #tab-mac-linux:checked ~ .install-card .label-mac-linux,
      #tab-windows:checked ~ .install-card .label-windows,
      #tab-claude:checked ~ .install-card .label-claude,
      #tab-codex:checked ~ .install-card .label-codex,
      #tab-opencode:checked ~ .install-card .label-opencode {
        color: var(--text);
        border-bottom-color: var(--text);
      }

      #tab-mac-linux:checked ~ .install-card .panel-mac-linux,
      #tab-windows:checked ~ .install-card .panel-windows,
      #tab-claude:checked ~ .install-card .panel-claude,
      #tab-codex:checked ~ .install-card .panel-codex,
      #tab-opencode:checked ~ .install-card .panel-opencode {
        display: grid;
      }

      /* --- store buttons --- */

      .download-actions {
        display: flex;
        gap: 12px;
      }

      .store-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: 200px;
        padding: 9px 12px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: #111112;
        color: var(--text);
        text-decoration: none;
        font-weight: 500;
        transition: border-color 0.18s;
      }

      .store-btn:hover {
        border-color: var(--border-strong);
      }

      :global(.store-icon) {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
      }

      .store-copy {
        display: grid;
        gap: 2px;
        font-size: 14px;
        color: var(--muted);
      }

      .store-copy strong {
        font-size: 14px;
        color: var(--text);
      }

      .download-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 18px;
        margin-top: 12px;
        font-size: 13px;
      }

      .download-links a {
        color: var(--muted);
        text-decoration: underline;
        text-underline-offset: 4px;
        text-decoration-color: rgba(255, 255, 255, 0.18);
        transition:
          color 0.18s,
          text-decoration-color 0.18s;
      }

      .download-links a:hover {
        color: var(--text);
        text-decoration-color: var(--text);
      }

      @media (max-width: 480px) {
        .store-btn {
          padding: 8px 12px;
          gap: 8px;
        }

        :global(.store-icon) {
          width: 18px;
          height: 18px;
        }
      }

      /* --- social links --- */

      .social-links {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
      }

      .social-btn {
        display: inline-flex;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.18s;
      }

      .social-btn:hover {
        color: var(--text);
      }

      :global(.social-icon) {
        width: 28px;
        height: 28px;
      }

      :global(.social-icon#xcom) {
        width: 22px;
        height: 22px;
      }

      .right {
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* --- phone mockup --- */

      .phone-mockup {
        position: relative;
        width: 380px;
        aspect-ratio: 435 / 890;
        filter: drop-shadow(0 40px 100px rgba(0, 0, 0, 0.7))
          drop-shadow(0 8px 24px rgba(0, 0, 0, 0.4));
      }

      /* device frame drawn by frame.png overlay (buttons, island, bezel) */
      .phone-mockup::after {
        content: "";
        position: absolute;
        inset: 0;
        background: url("/frame.png") center / contain no-repeat;
        opacity: 0.8;
        pointer-events: none;
        z-index: 10;
      }

      .phone-screen {
        position: absolute;
        inset: 2.25% 5.52% 2.36% 5.29%;
        border-radius: 7.8% / 3.8%;
        overflow: hidden;
        background: #000;
      }

      .phone-screen video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: contrast(1.05) saturate(1.2);
      }

      @media (max-width: 1024px) {
        .hero {
          grid-template-columns: 1fr;
        }

        .hero .left {
          margin: auto;
        }
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 0 20px;
        border-top: 1px solid var(--border);
      }

      footer nav {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        font-size: 14px;
        transition: color 0.18s;
      }

      footer a:hover {
        color: var(--text);
      }

      footer .social-links {
        margin-top: 0;
      }

      @media (max-width: 640px) {
        body {
          padding: 18px 12px;
        }

        .page {
          min-height: auto;
          gap: 24px;
        }

        .hero {
          min-height: auto;
        }

        .section {
          padding: 64px 0 40px;
        }

        .install-card {
          height: auto;
          min-height: 180px;
        }

        .tab-label {
          gap: 6px;
          font-size: 12px;
          min-width: 40px;
          justify-content: center;
        }

        .logo {
          font-size: 22px;
        }

        .logo-icon {
          width: 30px;
          height: 36px;
        }

        .description {
          font-size: 14px;
          line-height: 1.65;
        }

        .left {
          gap: 28px;
        }

        .hero-intro {
          gap: 14px;
        }

        .store-copy strong {
          font-size: 13px;
        }

        .store-copy span {
          font-size: 12px;
        }

        .store-btn {
          width: auto;
          flex: 1;
        }

        .download-actions {
          gap: 8px;
          justify-content: center;
        }

        .download-links {
          justify-content: center;
        }

        footer {
          flex-direction: column;
          gap: 16px;
        }

        footer nav {
          justify-content: center;
        }

        .social-links {
          margin-top: 0;
          justify-content: center;
          gap: 28px;
        }

        .phone-mockup {
          width: min(400px, 90vw);
          height: auto;
        }

        .tab-label-text {
          display: none;
        }

        .tab-panels {
          padding: 10px;
        }

        .tab-list {
          padding: 6px 10px 0;
          gap: 4px;
        }

        .terminal-code {
          font-size: 12px;
        }

        .copy-btn {
          display: none;
        }

        h1 {
          font-size: clamp(30px, 9.5vw, 56px);
        }

        .section h2 {
          font-size: 26px;
        }

        .ws-head h2 {
          font-size: 22px;
        }

        .scrolly-step h3 {
          font-size: 20px;
        }

        .section > p,
        .section .lede,
        .ws-head .lede {
          font-size: 15px;
        }

        .faq-list summary {
          font-size: 15px;
        }

        .faq-list p {
          font-size: 14px;
        }
      }

      /* Touch devices have no hover; reveal the button on focus instead. */
      @media (hover: none) {
        .install-block:focus-within .copy-btn {
          opacity: 1;
        }
      }
    </style>
  </head>
  <body>
    <canvas id="bg-shader" aria-hidden="true"></canvas>
    <div class="page">
      <main class="hero">
        <section id="hero-main-content" class="left">
          <div class="hero-copy">
            <a class="logo" href="/">
              <svg
                class="logo-icon"
