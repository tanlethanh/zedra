      <section class="section" aria-labelledby="tech-heading">
        <p class="section-label" data-reveal>why-zedra</p>
        <h2 id="tech-heading" data-reveal>Why Zedra?</h2>
        <p class="lede" data-reveal>
          Agent-neutral workflows, fast P2P networking, GPUI rendering, and mobile-native design
          in one open developer tool.
        </p>
        <canvas
          id="rev-canvas"
          data-reveal
          role="img"
          aria-label="Animated waveform with the technologies behind Zedra: GPUI, Metal, wgpu, Vulkan, iroh, QUIC, TLS 1.3"
        >
          GPUI · Metal · wgpu · Vulkan · iroh · QUIC/UDP · TLS 1.3
        </canvas>
        <div class="feature-list">
          {
            techPillars.map((pillar, i) => (
              <div class="feature-row" data-reveal style={`--reveal-delay: ${i * 80}ms`}>
                <h3>{pillar.title}</h3>
                <p>{pillar.body}</p>
