const demoVideo = "/zedra-demo.mp4";

const pageTitle = "Zedra — Mobile remote editor. Code from anywhere.";
const pageDescription =
  "Zedra is a mobile code editor for your desktop workspace. Browse files, read code, review git diffs, run terminals, and control AI coding agents over an encrypted P2P tunnel.";
const canonicalUrl = "https://zedra.dev/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#090909" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="application-name" content="Zedra" />
    <meta name="apple-mobile-web-app-title" content="Zedra" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Zedra" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://zedra.dev/OG.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@zedradev" />
    <meta name="twitter:creator" content="@zedradev" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="https://zedra.dev/OG.png" />
    <meta name="twitter:image:alt" content="Zedra — remote coding on mobile" />
    <meta property="og:image:alt" content="Zedra — remote coding on mobile" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-192.png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Zedra",
        description: pageDescription,
        url: canonicalUrl,
        applicationCategory: "DeveloperApplication",
        operatingSystem: "iOS, Android",
        offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
        author: { "@type": "Organization", name: "Zedra", url: canonicalUrl },
      })}
    />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Lora:wght@400&display=swap");

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --bg: #090909;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --text: #f3f4f6;
        --muted: #59595e;
        --green: #3dd68c;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: "IBM Plex Mono", "SF Mono", "Fira Code", monospace;
      }

      body {
        padding: 32px;
      }

      .page {
        max-width: 1280px;
        margin: 0 auto;
        min-height: calc(100vh - 64px);
        display: grid;
        grid-template-rows: 1fr auto;
        gap: 32px;
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 16px;
        color: var(--text);
        text-decoration: none;
        font-size: 2.1rem;
        font-weight: 400;
        letter-spacing: 0.02em;
        font-family: "Lora", Georgia, serif;
      }

      .logo-icon {
        width: 36px;
        height: 46px;
        flex-shrink: 0;
      }

      .logo span {
        color: var(--green);
      }

      .placeholder-link {
        color: var(--muted);
        text-decoration: none;
        transition: color 0.18s ease;
      }

      .placeholder-link:hover {
        color: var(--text);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
        gap: 32px;
        align-items: stretch;
      }

      .left {
        min-width: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 28px;
      }

      .hero-copy {
        display: grid;
        gap: 18px;
      }

      .hero-intro {
        display: grid;
        gap: 14px;
      }

      h1 {
        margin: 0;
        max-width: 10ch;
        font-size: clamp(3rem, 6vw, 5.5rem);
        line-height: 0.96;
        letter-spacing: -0.05em;
      }

      .description {
        margin: 0;
        max-width: 620px;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.75;
      }

      .install-widget {
        display: grid;
        gap: 12px;
      }

      .tab-input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }

      /* --- install card (terminal widget) --- */

      .install-card {
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: #111112;
        height: 196px;
      }

      .tab-list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        padding: 8px 14px 0;
      }

      .tab-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 2px 9px;
        border: none;
        border-bottom: 1px solid transparent;
        background: transparent;
        color: var(--muted);
        font-size: 0.78rem;
        cursor: pointer;
        transition:
          color 0.18s,
          border-color 0.18s;
      }

      .tab-label:hover {
        color: var(--text);
        border-bottom-color: rgba(255, 255, 255, 0.3);
      }

      :global(.tab-icon) {
        width: 15px;
        height: 15px;
        flex-shrink: 0;
      }

      .tab-panel {
        display: none;
      }

      .tab-panels {
        padding: 14px;
      }

      .terminal-code {
        display: grid;
        gap: 10px;
        font-size: 0.9rem;
        line-height: 1.6;
      }

      .install-block {
        position: relative;
        display: grid;
        gap: 2px;
      }

      .terminal-comment {
        color: var(--muted);
      }

      .terminal-command {
        margin: 0;
        white-space: pre-wrap;
        word-break: break-word;
      }

      .copy-btn {
        position: absolute;
        top: 0;
        right: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 2px;
        background: transparent;
        border: none;
        cursor: pointer;
        color: var(--muted);
        opacity: 0;
        transition:
          opacity 0.15s,
          color 0.15s;
      }

      .install-block:hover .copy-btn {
        opacity: 1;
      }

      .copy-btn:hover {
        color: var(--text);
      }

      /* checked-tab state (CSS-only tabs) */

      #tab-curl:checked ~ .install-card .label-curl,
      #tab-claude:checked ~ .install-card .label-claude,
      #tab-codex:checked ~ .install-card .label-codex,
      #tab-opencode:checked ~ .install-card .label-opencode,
      #tab-gemini:checked ~ .install-card .label-gemini {
        color: var(--text);
        border-bottom-color: var(--text);
      }

      #tab-curl:checked ~ .install-card .panel-curl,
      #tab-claude:checked ~ .install-card .panel-claude,
      #tab-codex:checked ~ .install-card .panel-codex,
      #tab-opencode:checked ~ .install-card .panel-opencode,
      #tab-gemini:checked ~ .install-card .panel-gemini {
        display: grid;
      }

      /* --- store buttons --- */

      .download-actions {
        display: flex;
        gap: 16px;
      }

      .store-btn {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        width: 200px;
        padding: 12px 14px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.02);
        color: var(--text);
        text-decoration: none;
        font-weight: 500;
        transition: border-color 0.18s;
      }

      .store-btn:hover {
        border-color: var(--border-strong);
      }

      .store-btn.secondary {
        color: var(--muted);
      }

      :global(.store-icon) {
        width: 24px;
        height: 24px;
        flex-shrink: 0;
      }

      .store-copy {
        display: grid;
        gap: 2px;
        font-size: 0.78rem;
        color: var(--muted);
      }

      .store-copy strong {
        font-size: 0.92rem;
        color: var(--text);
      }

      .store-btn.secondary .store-copy strong {
        color: var(--muted);
      }

      /* --- social links --- */

      .ph-badge {
        display: inline-block;
        line-height: 0;
      }

      .social-links {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 24px;
      }

      .social-btn {
        display: inline-flex;
        color: var(--muted);
        text-decoration: none;
        transition: color 0.18s;
      }

      .social-btn:hover {
        color: var(--text);
      }

      :global(.social-icon) {
        width: 28px;
        height: 28px;
      }

      :global(.social-icon#xcom) {
        width: 22px;
        height: 22px;
      }

      .right {
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* --- phone mockup --- */

      .phone-mockup {
        position: relative;
        width: 360px;
        aspect-ratio: 390 / 844;
        background: #1c1c1e;
        border-radius: 50px;
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.12),
          0 0 0 6px #1c1c1e,
          0 0 0 7px rgba(255, 255, 255, 0.07),
          0 40px 100px rgba(0, 0, 0, 0.7),
          0 8px 24px rgba(0, 0, 0, 0.4);
      }

      .phone-btn {
        position: absolute;
        background: #2c2c2e;
        border-radius: 2px;
      }

      .phone-btn-action {
        left: -3px;
        top: 14%;
        width: 3px;
        height: 5%;
        border-radius: 2px 0 0 2px;
      }

      .phone-btn-vol-up {
        left: -3px;
        top: 22%;
        width: 3px;
        height: 8%;
        border-radius: 2px 0 0 2px;
      }

      .phone-btn-vol-down {
        left: -3px;
        top: 32%;
        width: 3px;
        height: 8%;
        border-radius: 2px 0 0 2px;
      }

      .phone-btn-power {
        right: -3px;
        top: 24%;
        width: 3px;
        height: 12%;
        border-radius: 0 2px 2px 0;
      }

      .phone-screen {
        position: absolute;
        inset: 6px;
        border-radius: 44px;
        overflow: hidden;
        background: #000;
      }

      .phone-dynamic-island {
        position: absolute;
        top: 12px;
        left: 50%;
        transform: translateX(-50%);
        width: 34%;
        height: 3.8%;
        background: #000;
        border-radius: 20px;
        z-index: 10;
      }

      .phone-screen video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      @media (max-width: 1024px) {
        .hero {
          grid-template-columns: 1fr;
        }

        .phone-mockup {
          width: 280px;
        }
      }

      footer {
        padding: 24px 0 8px;
        border-top: 1px solid var(--border);
      }

      footer nav {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
      }

      footer a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.78rem;
        transition: color 0.18s;
      }

      footer a:hover {
        color: var(--text);
      }

      @media (max-width: 640px) {
        body {
          padding: 18px 12px;
        }

        .page {
          min-height: auto;
          gap: 24px;
        }

        .install-card {
          height: auto;
          min-height: 180px;
        }

        .demo-card {
          padding: 20px;
          border-radius: 22px;
        }

        .logo {
          font-size: 1.4rem;
        }

        .logo-icon {
          width: 30px;
          height: 36px;
        }

        .description {
          font-size: 0.85rem;
          line-height: 1.65;
        }

        .store-copy strong {
          font-size: 0.82rem;
        }

        .store-copy span {
          font-size: 0.72rem;
        }

        .store-btn {
          width: auto;
          flex: 1;
        }

        .download-actions {
          gap: 8px;
          justify-content: center;
        }

        .ph-badge {
          display: block;
          text-align: center;
        }

        .social-links {
          margin-top: 16px;
          justify-content: center;
          gap: 28px;
        }

        .phone-mockup {
          width: min(400px, 90vw);
        }

        .tab-label-text {
          display: none;
        }

        .tab-label {
          min-width: 40px;
          justify-content: center;
        }

        .tab-panels {
          padding: 10px;
        }

        .tab-list {
          padding: 6px 10px 0;
          gap: 4px;
        }

        .terminal-code {
          font-size: 0.76rem;
        }

        .copy-btn {
          display: none;
        }

        h1 {
          font-size: clamp(2.2rem, 12vw, 3.5rem);
        }
      }

      /* Always show copy button on touch devices (no hover) */
      @media (hover: none) {
        .copy-btn {
          opacity: 1;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <main class="hero">
        <section class="left">
          <div class="hero-copy">
            <a class="logo" href="/">
              <svg
                class="logo-icon"
                viewBox="0 0 351 442"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M18.3179 221.467L256.976 20.945L163.07 154.216L338.989 154.216L95.8202 420.758L211.868 221.467L18.3179 221.467Z"
                  fill="white"
                  fill-opacity="0.2"></path>
                <path
                  d="M83.5193 208.633L230.794 57.4409L171.954 169.12H271.329L120.967 378.111L197.026 208.633H83.5193Z"
                  fill="white"></path>
              </svg>
              Zedra
            </a>

            <div class="hero-intro">
              <h1>Code from anywhere.</h1>
              <p class="description">
                Mobile code editor for your desktop workspace. Browse files,
                read code, review git diffs, run terminals, and control AI
                coding agents over an encrypted P2P tunnel.
              </p>
            </div>
          </div>

          <section class="install-widget" aria-label="Install">
            {
              installTabs.map((tab, index) => (
                <input
                  class="tab-input"
                  type="radio"
                  name="install-tabs"
                  id={`tab-${tab.id}`}
                  data-analytics-install-tab={tab.id}
                  checked={index === 0}
                />
              ))
            }

            <div class="install-card">
              <div
                class="tab-list"
                role="tablist"
                aria-label="Installation methods"
              >
                {
                  installTabs.map((tab) => (
                    <label
                      class={`tab-label label-${tab.id}`}
                      for={`tab-${tab.id}`}
                    >
                      <Fragment set:html={tab.icon} />
                      <span class="tab-label-text">{tab.label}</span>
                    </label>
                  ))
                }
              </div>

              <div class="tab-panels">
                {
                  installTabs.map((tab) => (
                    <section class={`tab-panel panel-${tab.id}`}>
                      <div class="terminal-code">
                        {tab.blocks.map((block) => {
                          const copyText = block
                            .filter((l) => !l.comment)
                            .map((l) => l.text)
                            .join("\n");
                          return (
                            <div class="install-block" data-copy={copyText}>
                              {block.map((line) =>
                                // prettier-ignore
                                <code class={line.comment ? "terminal-comment" : "terminal-command"}>{line.text}</code>,
                              )}
                              <button
                                class="copy-btn"
                                aria-label="Copy to clipboard"
                                title="Copy"
                              >
                                <svg
                                  width="18"
                                  height="18"
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  aria-hidden="true"
                                >
                                  <rect
                                    x="9"
                                    y="9"
                                    width="13"
                                    height="13"
                                    rx="2"
                                    ry="2"
                                  />
                                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                                </svg>
                              </button>
                            </div>
                          );
                        })}
                      </div>
                    </section>
                  ))
                }
              </div>
            </div>

            <div class="download-actions">
              {
                storeLinks.map((link) => (
                  <a
                    class={link.className}
                    href={link.href}
                    aria-label={link.ariaLabel}
                    data-analytics-store={link.analyticsName}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Fragment set:html={link.icon} />
                    <span class="store-copy">
                      <strong>{link.title}</strong>
                      <span>{link.subtitle}</span>
                    </span>
                  </a>
                ))
              }
            </div>

            <a
              class="ph-badge"
              href="https://www.producthunt.com/products/zedra-mobile-ide-for-ai?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-zedra"
              target="_blank"
              rel="noopener noreferrer"
            >
              <img
                alt="Zedra - Code from anywhere | Product Hunt"
                width="250"
                height="54"
                src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1097175&theme=dark&t=1774597535210"
              />
            </a>

            <div class="social-links" aria-label="Zedra social links">
              {
                socialLinks.map((link) => (
                  <a
                    class="social-btn"
                    href={link.href}
                    aria-label={link.ariaLabel}
                    data-analytics-social={link.analyticsName}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Fragment set:html={link.icon} />
                  </a>
                ))
              }
            </div>
          </section>
        </section>

        <aside class="right">
          <div class="phone-mockup" aria-label="Zedra app demo">
            <div class="phone-btn phone-btn-action"></div>
            <div class="phone-btn phone-btn-vol-up"></div>
            <div class="phone-btn phone-btn-vol-down"></div>
            <div class="phone-btn phone-btn-power"></div>
            <div class="phone-screen">
              <div class="phone-dynamic-island"></div>
              <video src={demoVideo} autoplay muted loop playsinline></video>
            </div>
          </div>
        </aside>
      </main>
      <footer>
        <nav aria-label="Site links">
          <a href="/privacy">Privacy Policy</a>
          <a href="/support">Support</a>
          <a
            href="https://github.com/tanlethanh/zedra"
            target="_blank"
            rel="noopener noreferrer">GitHub</a
          >
        </nav>
      </footer>
    </div>
    <script src="../scripts/analytics.ts"></script>
    <script>
      const CHECK_ICON = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
      const COPY_ICON = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;

      document.querySelectorAll(".copy-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const installBlock = btn.closest(
            ".install-block",
          ) as HTMLElement | null;
          const text = installBlock?.dataset.copy ?? "";
          try {
            await navigator.clipboard.writeText(text);
            btn.innerHTML = CHECK_ICON;
            setTimeout(() => {
              btn.innerHTML = COPY_ICON;
            }, 1500);
          } catch {}
        });
      });
    </script>
  </body>
</html>
