                  data-analytics-install-tab={tab.id}
                  checked={index === 0}
                />
              ))
            }

            <div class="install-card">
              <div
                class="tab-list"
                role="tablist"
                aria-label="Installation methods"
              >
                {
                  installTabs.map((tab) => (
                    <label
                      class={`tab-label label-${tab.id}`}
                      for={`tab-${tab.id}`}
                    >
                      <Fragment set:html={tab.icon} />
                      <span class="tab-label-text">{tab.label}</span>
                    </label>
                  ))
                }
              </div>

              <div class="tab-panels">
                {
                  installTabs.map((tab) => (
                    <section class={`tab-panel panel-${tab.id}`}>
                      <div class="terminal-code">
                        {tab.blocks.map((block) => {
                          const copyText = block
                            .filter((l) => !l.comment)
                            .map((l) => l.text)
                            .join("\n");
                          return (
                            <div class="install-block" data-copy={copyText}>
                              {block.map((line) =>
                                // prettier-ignore
                                <code class={line.comment ? "terminal-comment" : "terminal-command"}>{line.text}</code>,
                              )}
                              <button
                                class="copy-btn"
                                aria-label="Copy to clipboard"
                                title="Copy"
                              >
                                <svg
                                  width="18"
                                  height="18"
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  aria-hidden="true"
                                >
                                  <rect
                                    x="9"
                                    y="9"
                                    width="13"
                                    height="13"
                                    rx="2"
                                    ry="2"
                                  />
                                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
                                </svg>
                              </button>
                            </div>
                          );
                        })}
                      </div>
                    </section>
                  ))
                }
              </div>
            </div>

            <div class="download-actions">
              {
                storeLinks.map((link) => (
                  <a
                    class={link.className}
                    href={link.href}
                    aria-label={link.ariaLabel}
                    data-analytics-store={link.analyticsName}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <Fragment set:html={link.icon} />
                    <span class="store-copy">
                      <strong>{link.title}</strong>
                      <span>{link.subtitle}</span>
                    </span>
                  </a>
                ))
              }
            </div>
            <div class="download-links" aria-label="Project links">
              {
                downloadLinks.map((link) => (
                  <a
                    href={link.href}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>

          </section>
        </section>

        <aside class="right">
          <div class="phone-mockup" aria-label="Zedra app demo">
            <div class="phone-screen">
              <video src={demoVideo} autoplay muted loop playsinline></video>
            </div>
          </div>
        </aside>
      </main>

      <section class="section section-center" aria-labelledby="features-heading">
        <div class="ws-head" data-reveal>
          <p class="section-label">workspace</p>
          <h2 id="features-heading">A developer workspace</h2>
          <p class="lede">
            Not a chat window. A workspace lets you inspect the code, review the diff, and keep
            the agent moving.
          </p>
        </div>
        <div class="scrolly">
          <div class="scrolly-demo" aria-hidden="true">
            <div class="demo-frame">
              {
                features.map((feature, i) => (
                  <div
                    class={`demo-slide${i === 0 ? " active" : ""}${feature.demoImg ? " has-img" : ""}`}
                    data-slide={i}
                  >
                    {feature.demoImg ? (
                      <Picture
                        src={feature.demoImg}
                        alt=""
                        loading="lazy"
                        decoding="async"
                        formats={demoImageFormats}
                        fallbackFormat="png"
                        widths={demoImageWidths}
                        sizes={demoImageSizes}
                        quality={demoImageQuality}
                      />
                    ) : (
                      <>
                        <span class="demo-label">{feature.demo}</span>
                        <span class="demo-caption">device capture coming soon</span>
                      </>
                    )}
                  </div>
                ))
              }
            </div>
          </div>
          <div class="scrolly-content">
            <div class="scrolly-steps">
              {
                features.map((feature, i) => (
                  <div class={`scrolly-step${i === 0 ? " active" : ""}`} data-step={i}>
                    <div class="step-title">
                      <Fragment set:html={feature.icon} />
