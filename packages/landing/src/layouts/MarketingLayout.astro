---
// Shared shell for marketing pages (/claude-code, /codex, /compare, ...).
// Matches the landing page: dark, IBM Plex Mono, same tokens and footer.
interface Props {
  title: string;
  description: string;
  path: string; // e.g. "/claude-code" — used for canonical + og:url
  jsonLd?: object[];
}

const { title, description, path, jsonLd = [] } = Astro.props;
// Trailing slash matches @astrojs/sitemap output — canonical and sitemap
// must agree or Google treats them as two URLs.
const canonicalUrl = path === "/" ? "https://zedra.dev/" : `https://zedra.dev${path}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#090909" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Zedra" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://zedra.dev/OG.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Zedra: a real dev workspace on your phone" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@zedradev" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://zedra.dev/OG.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    <style is:global>
      @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Lora:wght@400&display=swap");

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --bg: #090909;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --text: #f3f4f6;
        --muted: #8b8b92;
        --dim: #59595e;
        --green: #3dd68c;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: "IBM Plex Mono", "SF Mono", "Fira Code", monospace;
      }

      body {
        padding: 32px 32px 0;
      }

      .mk-page {
        max-width: 760px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 40px;
        min-height: calc(100vh - 32px);
      }

      .mk-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .mk-logo {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--text);
        text-decoration: none;
        font-size: 22px;
        font-family: "Lora", Georgia, serif;
      }

      .mk-logo-icon {
        width: 26px;
        height: 32px;
        flex-shrink: 0;
      }

      .mk-header nav {
        display: flex;
        gap: 20px;
      }

      .mk-header nav a {
        color: var(--muted);
        text-decoration: none;
        font-size: 14px;
        transition: color 0.18s;
      }

      .mk-header nav a:hover {
        color: var(--text);
      }

      main.mk-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }

      .mk-content h1 {
        margin: 24px 0 0;
        font-family: "Lora", Georgia, serif;
        font-weight: 400;
        font-size: clamp(28px, 4.5vw, 36px);
        line-height: 1.15;
        letter-spacing: 0.01em;
      }

      .mk-content h2 {
        margin: 32px 0 0;
        font-family: "Lora", Georgia, serif;
        font-weight: 400;
        font-size: 24px;
        letter-spacing: 0.01em;
      }

      .mk-content p,
      .mk-content li {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.75;
      }

      .mk-content ul {
        margin: 0;
        padding-left: 20px;
        display: grid;
        gap: 8px;
      }

      .mk-content a {
        color: var(--text);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--dim);
      }

      .mk-content a:hover {
        text-decoration-color: var(--text);
      }

      .mk-content strong {
        color: var(--text);
      }

      .mk-code {
        margin: 0;
        padding: 14px;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: #111112;
        font-size: 13.5px;
        line-height: 1.6;
        overflow-x: auto;
      }

      .mk-code .c {
        color: var(--dim);
      }

      .mk-steps {
        display: grid;
        gap: 20px;
        counter-reset: step;
      }

      .mk-step {
        display: grid;
        gap: 10px;
      }

      .mk-step h3 {
        margin: 0;
        font-size: 16px;
        counter-increment: step;
      }

      .mk-step h3::before {
        content: "0" counter(step) " ";
        color: var(--green);
        margin-right: 4px;
      }

      .mk-faq {
        display: grid;
      }

      .mk-faq details {
        border-top: 1px solid var(--border);
      }

      .mk-faq details:first-child {
        border-top: none;
      }

      .mk-faq summary {
        cursor: pointer;
        font-size: 15px;
        color: var(--text);
        padding: 14px 0;
        list-style: none;
        display: flex;
        align-items: baseline;
        gap: 12px;
      }

      .mk-faq summary::-webkit-details-marker {
        display: none;
      }

      .mk-faq summary::before {
        content: "+";
        color: var(--muted);
        flex-shrink: 0;
      }

      .mk-faq details[open] summary::before {
        content: "−";
      }

      .mk-faq summary:hover {
        color: var(--green);
      }

      .mk-faq p {
        margin: 0;
        padding: 0 0 16px 27px;
      }

      .mk-table-wrap {
        overflow-x: auto;
        border-top: 1px solid var(--border-strong);
        border-bottom: 1px solid var(--border-strong);
      }

      .mk-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13.5px;
        min-width: 640px;
      }

      .mk-table th,
      .mk-table td {
        padding: 12px 14px;
        text-align: left;
        vertical-align: top;
        border-bottom: 1px solid var(--border);
        color: var(--muted);
        line-height: 1.55;
      }

      .mk-table th {
        color: var(--text);
        font-weight: 500;
        white-space: nowrap;
      }

      .mk-table tr:last-child td {
        border-bottom: none;
      }

      .mk-table td:first-child {
        color: var(--text);
        white-space: nowrap;
      }

      .mk-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        padding: 14px 0 20px;
        border-top: 1px solid var(--border);
      }

      .mk-footer nav {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
      }

      .mk-footer a {
        color: var(--dim);
        text-decoration: none;
        font-size: 14px;
        transition: color 0.18s;
      }

      .mk-footer a:hover {
        color: var(--text);
      }

      @media (max-width: 640px) {
        body {
          padding: 18px 16px 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="mk-page">
      <header class="mk-header">
        <a class="mk-logo" href="/">
          <svg
            class="mk-logo-icon"
            viewBox="0 0 351 442"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M18.3179 221.467L256.976 20.945L163.07 154.216L338.989 154.216L95.8202 420.758L211.868 221.467L18.3179 221.467Z"
              fill="white"
              fill-opacity="0.2"></path>
            <path
              d="M83.5193 208.633L230.794 57.4409L171.954 169.12H271.329L120.967 378.111L197.026 208.633H83.5193Z"
              fill="white"></path>
          </svg>
          Zedra
        </a>
        <nav aria-label="Site links">
          <a href="/docs">Docs</a>
          <a href="https://github.com/tanlethanh/zedra" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://discord.gg/39MmkSS8sc" target="_blank" rel="noopener noreferrer">Discord</a>
        </nav>
      </header>

      <main class="mk-content">
        <slot />
      </main>

      <footer class="mk-footer">
        <nav aria-label="Footer links">
          <a href="/docs">Docs</a>
          <a href="/claude-code">Claude Code</a>
          <a href="/codex">Codex</a>
          <a href="/opencode">OpenCode</a>
          <a href="/compare">Compare</a>
          <a href="/privacy">Privacy</a>
          <a href="/support">Support</a>
        </nav>
      </footer>
    </div>
    <script src="../scripts/analytics.ts"></script>
  </body>
</html>
