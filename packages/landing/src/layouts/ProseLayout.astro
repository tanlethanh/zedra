---
const { frontmatter } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{frontmatter.title}</title>
    <meta name="description" content={frontmatter.description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#090909" />
    <link rel="canonical" href={frontmatter.canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      @import url("https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Lora:wght@400&display=swap");

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --bg: #090909;
        --border: rgba(255, 255, 255, 0.08);
        --border-strong: rgba(255, 255, 255, 0.14);
        --text: #f3f4f6;
        --secondary: #d6d6d6;
        --muted: #59595e;
      }

      html,
      body {
        margin: 0;
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: "IBM Plex Mono", "SF Mono", "Fira Code", monospace;
      }

      body {
        padding: 32px;
      }

      .page {
        max-width: 720px;
        margin: 0 auto;
        display: grid;
        grid-template-rows: auto 1fr auto;
        gap: 48px;
        min-height: calc(100vh - 64px);
      }

      /* header */
      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .site-header nav {
        display: flex;
        gap: 20px;
      }

      .site-header nav a {
        color: #8b8b92;
        text-decoration: none;
        font-size: 14px;
        transition: color 0.15s;
      }

      .site-header nav a:hover {
        color: var(--text);
      }

      .logo {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--text);
        text-decoration: none;
        font-size: 22px;
        font-weight: 400;
        letter-spacing: 0.02em;
        font-family: "Lora", Georgia, serif;
      }

      .logo-icon {
        width: 26px;
        height: 32px;
        flex-shrink: 0;
      }

      /* prose */
      .prose {
        display: grid;
        gap: 0;
      }

      .prose :global(h1) {
        margin: 0 0 8px;
        font-size: clamp(1.6rem, 4vw, 2.4rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: var(--text);
      }

      .prose :global(h2) {
        margin: 40px 0 16px;
        padding-top: 32px;
        border-top: 1px solid var(--border);
        font-size: 0.78rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.55);
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .prose :global(p) {
        margin: 0 0 14px;
        color: var(--secondary);
        font-size: 0.9rem;
        line-height: 1.85;
      }

      .prose :global(p strong) {
        color: var(--text);
        font-weight: 500;
      }

      .prose :global(ul) {
        margin: 0 0 14px;
        padding-left: 1.3em;
        display: grid;
        gap: 8px;
      }

      .prose :global(li) {
        color: var(--secondary);
        font-size: 0.9rem;
        line-height: 1.75;
      }

      .prose :global(li strong) {
        color: var(--text);
        font-weight: 500;
      }

      .prose :global(blockquote) {
        margin: 0 0 20px;
        padding: 18px 20px;
        border: 1px solid var(--border-strong);
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.03);
        border-left: 3px solid rgba(255, 255, 255, 0.2);
      }

      .prose :global(blockquote p) {
        margin: 0;
      }

      .prose :global(code) {
        font-family: inherit;
        font-size: 0.85em;
        background: rgba(255, 255, 255, 0.06);
        padding: 1px 5px;
        border-radius: 4px;
        color: var(--text);
      }

      .prose :global(a) {
        color: var(--text);
        text-decoration-color: var(--border-strong);
        text-underline-offset: 3px;
        transition: color 0.15s;
      }

      .prose :global(a:hover) {
        color: var(--text);
        opacity: 0.7;
      }

      .updated {
        display: block;
        color: var(--muted);
        font-size: 0.82rem;
        margin-bottom: 40px;
      }

      /* footer */
      .site-footer {
        padding-top: 32px;
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }

      .footer-links {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
      }

      .footer-link {
        color: var(--muted);
        font-size: 14px;
        text-decoration: none;
        transition: color 0.15s;
      }

      .footer-link:hover {
        color: var(--text);
      }

      @media (max-width: 640px) {
        body {
          padding: 18px 12px;
        }
        .page {
          gap: 32px;
        }
        .logo {
          font-size: 1.4rem;
        }
        .logo-icon {
          width: 30px;
          height: 36px;
        }
        .site-footer {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <a class="logo" href="/">
          <svg
            class="logo-icon"
            viewBox="0 0 351 442"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M18.3179 221.467L256.976 20.945L163.07 154.216L338.989 154.216L95.8202 420.758L211.868 221.467L18.3179 221.467Z"
              fill="white"
              fill-opacity="0.2"></path>
            <path
              d="M83.5193 208.633L230.794 57.4409L171.954 169.12H271.329L120.967 378.111L197.026 208.633H83.5193Z"
              fill="white"></path>
          </svg>
          Zedra
        </a>
        <nav aria-label="Site links">
          <a href="/docs">Docs</a>
          <a href="https://github.com/tanlethanh/zedra" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://discord.gg/39MmkSS8sc" target="_blank" rel="noopener noreferrer">Discord</a>
        </nav>
      </header>

      <main class="prose">
        <slot />
      </main>

      <footer class="site-footer">
        <nav class="footer-links" aria-label="Footer links">
          <a class="footer-link" href="/docs">Docs</a>
          <a class="footer-link" href="/claude-code">Claude Code</a>
          <a class="footer-link" href="/codex">Codex</a>
          <a class="footer-link" href="/opencode">OpenCode</a>
          <a class="footer-link" href="/compare">Compare</a>
          <a class="footer-link" href="/privacy">Privacy</a>
          <a class="footer-link" href="/support">Support</a>
        </nav>
      </footer>
    </div>
  </body>
</html>
