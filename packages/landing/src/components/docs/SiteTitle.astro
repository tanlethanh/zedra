---
const { siteTitleHref } = Astro.locals.starlightRoute;
---

<a href={siteTitleHref} class="site-title sl-flex" translate="no">
  <svg
    class="logo-icon"
    viewBox="0 0 351 442"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path
      d="M18.3179 221.467L256.976 20.945L163.07 154.216L338.989 154.216L95.8202 420.758L211.868 221.467L18.3179 221.467Z"
      fill="white"
      fill-opacity="0.2"></path>
    <path
      d="M83.5193 208.633L230.794 57.4409L171.954 169.12H271.329L120.967 378.111L197.026 208.633H83.5193Z"
      fill="white"></path>
  </svg>
  <span>Zedra</span>
</a>

<style>
  .site-title {
    align-items: center;
    gap: 10px;
    font-family: "Lora", Georgia, serif;
    font-size: 1.15rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    white-space: nowrap;
    min-width: 0;
  }
  .logo-icon {
    width: 22px;
    height: 28px;
    flex-shrink: 0;
  }
  span {
    overflow: hidden;
  }
</style>
