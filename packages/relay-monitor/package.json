{
  "name": "relay-monitor",
  "version": "1.0.0",
  "private": true,
  "description": "Docker sidecar for relay health + Discord — built by deploy/relay",
  "scripts": {
    "monitor": "bun monitor.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:monitor",
    "build:monitor": "bun build --compile --target=bun-linux-arm64 monitor.ts --outfile dist/monitor"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
