<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- method: "app-store" exports an IPA for App Store / TestFlight submission.
         Use "ad-hoc" for direct device distribution, "development" for local testing.
         In Xcode 15+, "app-store-connect" with destination="upload" exports AND uploads
         in a single step, but requires the auth key flags every time. "app-store" keeps
         export and upload as separate steps, which makes it easier to save the IPA as a
         CI artifact before uploading. -->
    <key>method</key>
    <string>app-store</string>

    <key>teamID</key>
    <string>GHV27CNR5U</string>

    <!-- Strip bitcode — Bitcode upload is deprecated since Xcode 14.
         Apple no longer accepts apps with bitcode enabled. -->
    <key>uploadBitcode</key>
    <false/>

    <!-- Upload dSYMs so App Store Connect / Crashlytics can symbolicate crash reports.
         Firebase Crashlytics also uploads dSYMs via its post-build script, but having
         them in the App Store record is a useful fallback. -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Thinning: none exports a universal IPA. "thin-for-all-variants" produces
         per-device slices, but that is only useful for ad-hoc / enterprise.
         App Store slicing happens on Apple's servers after upload. -->
    <key>thinning</key>
    <string>&lt;none&gt;</string>
</dict>
</plist>
